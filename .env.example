# SynaMCPs local development secrets.
# Copy to .env for local use; do not commit real secret values.

SYNA_ADMIN_PASSWORD=change-me

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

EMBEDDING_API_KEY=replace-me
SUMMARIZATION_API_KEY=replace-me

# 32-byte key for encrypting upstream MCP auth secrets at rest (openssl rand -base64 32)
MCP_PROXY_SECRETS_KEY=replace-with-openssl-rand-base64-32
